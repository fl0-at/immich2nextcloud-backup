# ──────────────────────────────────────────────────────────────
# immich2nextcloud-backup – Environment Variables Template
# ──────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
#
# ── Global settings ──────────────────────────────────────────

# Base URL of your Immich instance (no trailing slash)
IMMICH_SERVER=https://immich.example.com

# Base URL of your Nextcloud instance (no trailing slash)
NC_BASE_URL=https://cloud.example.com

# Space-separated list of logical user identifiers.
# Each ID must be lowercase [a-z0-9_-] and is used to derive
# per-user env var names below.
USER_LIST=alice bob

# ── Per-user settings ────────────────────────────────────────
# Repeat these for every user listed in USER_LIST.

# -- alice --
IMMICH_API_KEY_alice=your-immich-api-key-for-alice
NC_USER_alice=alice
NC_PASS_alice=alice-nextcloud-app-password

# -- bob --
IMMICH_API_KEY_bob=your-immich-api-key-for-bob
NC_USER_bob=bob
NC_PASS_bob=bob-nextcloud-app-password

# ── Optional rclone settings ────────────────────────────────

# sync (default) mirrors local → remote, including deletions.
# copy only uploads new/changed files, never deletes remote files.
RCLONE_MODE=sync

# Bandwidth limit (default: 8M)
RCLONE_BWLIMIT=8M

# Parallel file transfers (default: 4)
RCLONE_TRANSFERS=4

# Parallel checkers (default: 4)
RCLONE_CHECKERS=4

# ── Optional cleanup ────────────────────────────────────────

# Delete local export files older than this many days.
# Leave empty or 0 to disable pruning.
# PRUNE_AFTER_DAYS=30

# ── Optional retry settings ─────────────────────────────────

# Number of retries on transient failures (default: 0 = no retry)
# RETRY_COUNT=2

# Seconds to wait between retries (default: 10)
# RETRY_DELAY_SECONDS=10

# ── Optional logging / debugging ────────────────────────────

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Output logs as JSON lines (default: false)
# JSON_LOG=false

# Dry-run mode: runs rclone with --dry-run, skips immich-go export (default: false)
# TEST_MODE=false
