# Minimal .env template — copy to .env and fill values (keep .env private)

# Global
IMMICH_SERVER=https://immich.example.com
NC_BASE_URL=https://cloud.example.com
USER_LIST="alice bob"

# Per-user credentials (example keys)
IMMICH_API_KEY_alice=
NC_USER_alice=alice
NC_PASS_alice=

IMMICH_API_KEY_bob=
NC_USER_bob=bob
NC_PASS_bob=

# Rclone defaults (override as needed)
RCLONE_BWLIMIT=8M
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=4
RCLONE_MODE=sync

# Optional housekeeping
PRUNE_AFTER_DAYS=90
RETRY_COUNT=3
RETRY_DELAY_SECONDS=30

# Build-time versions (optional)
IMMICH_GO_VERSION=latest
RCLONE_VERSION=latest
